# publish-social credentials. Copy to a stable .env and fill in the blanks:
#   mkdir -p ~/.config/publish-social && chmod 700 ~/.config/publish-social
#   cp .env.example ~/.config/publish-social/.env
#   chmod 600 ~/.config/publish-social/.env
# (Or point PUBLISH_SOCIAL_ENV at any path.) Never commit your real .env.
#
# Each OAuth platform has TWO tiers of values:
#   - APP credentials (client/app id + secret): inputs used to MINT a token.
#   - TOKEN / ID fields: the result of completing the OAuth flow. Leave these
#     empty until the flow finishes. An app id is NOT a user id; an app secret
#     is NOT an access token.
#
# Set up only the platforms you want. Missing creds means that platform is skipped.

# --- Bluesky ----------------------------------------------------------------
# App password (NOT your account password): Settings -> App Passwords.
BLUESKY_HANDLE=yourhandle.bsky.social
BLUESKY_APP_PASSWORD=

# --- Mastodon ---------------------------------------------------------------
# Access token from an instance app with the write:statuses and write:media scopes.
MASTODON_INSTANCE_URL=https://your.instance
MASTODON_ACCESS_TOKEN=

# --- Threads ----------------------------------------------------------------
# App credentials from the Meta app (Use cases -> Threads -> Settings):
THREADS_APP_ID=
THREADS_APP_SECRET=
THREADS_USERNAME=
# Filled in by the token exchange once OAuth completes (60-day token):
THREADS_USER_ID=
THREADS_ACCESS_TOKEN=

# --- LinkedIn ---------------------------------------------------------------
# Organization/page posting via the Community Management API (w_organization_social).
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
# Org URN looks like urn:li:organization:12345678
LINKEDIN_ORG_URN=
# Access token (60-day). Paste the access_token, NOT the refresh_token.
LINKEDIN_ACCESS_TOKEN=
# Refresh token (365-day), optional but recommended: if set, publish.py mints a
# fresh access token automatically near expiry (and manages
# LINKEDIN_TOKEN_EXPIRES_AT here on its own).
LINKEDIN_REFRESH_TOKEN=

# --- X / Twitter ------------------------------------------------------------
# Pay-per-use (about $0.015 per post, $0.20 if the post contains a link).
# OAuth 1.0a user context: use the OAuth 1.0a creds, NOT the OAuth 2.0 ones
# (Bearer Token, Client ID, and Client Secret are not used here).
X_API_KEY=
X_API_SECRET=
# Access Token + Secret (Keys and tokens -> Authentication Tokens -> Generate).
# Set the app to Read and write FIRST, then generate, or posting 403s. No expiry.
X_ACCESS_TOKEN=
X_ACCESS_TOKEN_SECRET=
# Optional: only used to build the post's permalink (your handle, no @).
X_USERNAME=

# --- Instagram --------------------------------------------------------------
# Content publishing to a Business/Creator account via the Graph API (Instagram
# Login). Requires Meta App Review for instagram_business_content_publish. Video
# posts go out as Reels. See README.md for the account + review prerequisites.
INSTAGRAM_APP_ID=
INSTAGRAM_APP_SECRET=
# Filled in by the token exchange once OAuth completes (60-day token):
INSTAGRAM_USER_ID=
INSTAGRAM_ACCESS_TOKEN=

# --- Facebook (Page) --------------------------------------------------------
# Post to a Facebook Page via the Graph API (pages_manage_posts). A Page access
# token minted from a long-lived user token is non-expiring, so no refresh is
# needed. Image/video are fetched by Facebook from the media host (below);
# text-only Page posts need no host. See README.md.
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
# Filled in after the OAuth flow + page-token exchange:
FACEBOOK_PAGE_ID=
FACEBOOK_PAGE_ACCESS_TOKEN=

# --- Media hosting (optional; image OR video on Threads/Instagram/Facebook) ---
# These platforms fetch media by public URL, so an image or video for them needs
# a public HTTPS host. Any host works: a small static file server, a VPS, object
# storage, or a tunnel exposing a local server. Bluesky / Mastodon / LinkedIn / X
# take a direct upload and need none of this. For video, the host must serve video
# extensions (.mp4, .mov, .m4v, .webm), not only images.
IMAGE_HOST_BASE_URL=https://img.example.com
IMAGE_HOST_SSH=your-image-host
IMAGE_HOST_PATH=~/images

# --- Image fetch (optional; for auto-sourcing a post image) -----------------
# Free Pexels API key for fetch_image.py. Get one at https://www.pexels.com/api/
PEXELS_API_KEY=

# --- Optional overrides -----------------------------------------------------
# Where publish.py looks for ready posts when run with --auto.
# Defaults to ~/social-posts if unset.
# SOCIAL_POSTS_DIR=~/social-posts
